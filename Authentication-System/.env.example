# ─── DATABASE ─────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# ─── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── EMAIL (Gmail SMTP with App Password) ─────────────────────────────────────
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=your@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# ─── FRONTEND URL (used in password reset emails) ─────────────────────────────
# Local dev:
# FRONTEND_URL=http://localhost:5173
# Production:
FRONTEND_URL=https://your-app.vercel.app

# ─── CLOUDINARY (optional — for persistent profile pic storage) ───────────────
# Sign up free at https://cloudinary.com — copy from your dashboard
# If not set, profile pics are saved locally (ephemeral on Render)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
